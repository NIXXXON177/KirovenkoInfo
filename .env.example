# ============================================
# Telegram Bot Configuration
# ============================================

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Chat IDs to send notifications to (comma or semicolon separated)
# Get your chat ID: https://t.me/userinfobot
CHAT_IDS=123456789

# ============================================
# Data Source Configuration
# ============================================

# Which data source to use: 'site' or 'database'
DATA_SOURCE=site

# Base URL of the site to monitor
BASE_URL=https://donatov.net

# Poll interval in seconds (how often to check for changes)
POLL_INTERVAL_SEC=120

# Request timeout in seconds
REQUEST_TIMEOUT_SEC=45

# ============================================
# Storage Configuration
# ============================================

# Path to store the state file (snapshots)
STATE_PATH=./data/state.json

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Optional: Database Configuration
# ============================================

# If DATA_SOURCE=database, configure these:
DATABASE_URL=postgresql+asyncpg://user:pass@127.0.0.1:5432/dbname
DB_TABLE_CATEGORIES=categories
DB_TABLE_GAMES=games
DB_TABLE_PRODUCTS=products
DB_CAT_ID=id
DB_CAT_NAME=name
DB_CAT_SLUG=slug
DB_GAME_ID=id
DB_GAME_NAME=name
DB_GAME_ENABLED=enabled
DB_GAME_DESCRIPTION=description
DB_PRODUCT_ID=id
DB_PRODUCT_NAME=name
DB_PRODUCT_PRICE=price
DB_PRODUCT_DESCRIPTION=description

# ============================================
# Optional: Telegram Proxy
# ============================================

# If you need to use a proxy to access Telegram API
TELEGRAM_PROXY=

# Telegram API timeout in seconds
TELEGRAM_TIMEOUT_SEC=120

# Number of retries for Telegram API requests
TELEGRAM_API_RETRIES=5

# ============================================
# Optional: Advanced Configuration
# ============================================

# Number of concurrent requests when fetching game pages
FETCH_CONCURRENCY=8
